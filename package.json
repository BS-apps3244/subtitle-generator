{
  "name": "subtitle-generator",
  "version": "0.1.8",
  "description": "Desktop subtitle generator for Premiere workflows using local Whisper.",
  "author": "Subtitle Generator Contributors",
  "main": "src/main.cjs",
  "scripts": {
    "start": "electron .",
    "check": "node --check src/main.cjs && node --check src/preload.cjs && node --check src/renderer.js && node tests/srt-rules.test.cjs",
    "prepare-whisper": "powershell -ExecutionPolicy Bypass -File scripts/prepare-whisper.ps1",
    "prepack": "npm run prepare-whisper",
    "pack": "electron-builder --dir",
    "predist": "npm run prepare-whisper",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "app.subtitlegenerator.desktop",
    "productName": "Subtitle Generator",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "BS-apps3244",
        "repo": "subtitle-generator"
      }
    ],
    "npmRebuild": false,
    "files": [
      "src/**/*",
      "package.json",
      "README.md"
    ],
    "extraResources": [
      {
        "from": "vendor/whisper",
        "to": "whisper",
        "filter": [
          "bin/Release/whisper-cli.exe",
          "bin/Release/*.dll",
          "ggml-base.en.bin"
        ]
      },
      {
        "from": "vendor/ffmpeg",
        "to": "ffmpeg",
        "filter": [
          "bin/ffmpeg.exe"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Subtitle-Generator-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^26.8.1"
  }
}
